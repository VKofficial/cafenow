{
  "entities": {
    "AdminAccount": {
      "title": "AdminAccount",
      "description": "An administrator account for the snooker club",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the administrator" },
        "username": { "type": "string", "description": "The username of the administrator" },
        "cipher": { "type": "string", "description": "The cipher/passcode for secondary verification" },
        "role": { "type": "string", "enum": ["admin", "admin1", "admin2", "admin3"], "description": "The administrative tier" },
        "permissions": { "type": "string", "enum": ["SNOOKER", "CAFE", "BOTH"], "description": "Functional permission level" }
      },
      "required": ["id", "username", "cipher", "role", "permissions"]
    },
    "SnookerTable": {
      "title": "SnookerTable",
      "description": "A table or station in the snooker club",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique table ID" },
        "number": { "type": "string", "description": "Display number or label of the table" },
        "type": { "type": "string", "enum": ["Snooker", "Pool", "PS5", "Mini Snooker", "Other Games"], "description": "The type of game table or station" },
        "status": { "type": "string", "enum": ["RUNNING", "AVAILABLE", "MAINTENANCE", "RESERVED"], "description": "The current status of the table" },
        "rate": { "type": "number", "description": "The hourly rate for using this table" },
        "rateUnit": { "type": "string", "enum": ["min", "hr"], "description": "The unit of the rate" },
        "player": { "type": "string", "description": "The name of the current player" },
        "billNumber": { "type": "string", "description": "The bill identifier" },
        "startTime": { "type": "string", "description": "Human-readable local start time" },
        "startTimeUnix": { "type": "number", "description": "Unix timestamp of session start" },
        "elapsedTime": { "type": "string", "description": "Accumulated or display time" },
        "sessionCost": { "type": "number", "description": "Cost generated by table usage so far" },
        "cafeCost": { "type": "number", "description": "Cost generated from canteen orders" },
        "cost": { "type": "number", "description": "Total combined session cost" },
        "currentCart": { "type": "array", "description": "List of cart items" },
        "isPaused": { "type": "boolean", "description": "Is the timer currently paused" },
        "totalPausedSeconds": { "type": "number", "description": "Sum of all paused time in seconds" },
        "pauseStartTimeUnix": { "type": "number", "description": "Unix timestamp of when the pause began" },
        "reservationTime": { "type": "string", "description": "Scheduled time of reservation" },
        "playersCount": { "type": "number", "description": "Number of players" },
        "note": { "type": "string", "description": "Custom note regarding the table state" },
        "currentMemberId": { "type": "string", "description": "Target ID of a reservation/current member" }
      },
      "required": ["id", "number", "type", "status", "rate", "rateUnit"]
    },
    "Member": {
      "title": "Member",
      "description": "A registered member of the snooker club",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique member identifier" },
        "name": { "type": "string", "description": "Full name of the member" },
        "contact": { "type": "string", "description": "Contact phone number or email" },
        "joinedDate": { "type": "string", "description": "Date they registered with the club" },
        "status": { "type": "string", "enum": ["Active", "Inactive"], "description": "Membership activity status" },
        "dueAmount": { "type": "number", "description": "Outstanding due balance" }
      },
      "required": ["id", "name", "contact", "joinedDate", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A historic billing transaction or entry in the club ledger",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction ID" },
        "date": { "type": "string", "description": "Transaction completion date" },
        "amount": { "type": "number", "description": "Total amount paid" },
        "paymentMethod": { "type": "string", "enum": ["CASH", "CARD", "UPI", "PAY_LATER"], "description": "Form of payment" },
        "tableNumber": { "type": "string", "description": "Table reference number" },
        "playerName": { "type": "string", "description": "Name of the player billing" },
        "memberId": { "type": "string", "description": "Associated member ID" },
        "items": { "type": "array", "description": "Canteen items associated with the bill" },
        "duration": { "type": "string", "description": "Total elapsed session duration" }
      },
      "required": ["id", "date", "amount", "paymentMethod", "tableNumber", "playerName", "duration"]
    },
    "Expenditure": {
      "title": "Expenditure",
      "description": "An expense item compiled by the snooker club",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique expenditure ID" },
        "date": { "type": "string", "description": "Transaction date" },
        "description": { "type": "string", "description": "What was purchased or resolved" },
        "amount": { "type": "number", "description": "Cost of the expense" },
        "category": { "type": "string", "enum": ["Supplies", "Maintenance", "Rent", "Utilities", "Salaries", "Other"], "description": "Categorization of expense" }
      },
      "required": ["id", "date", "description", "amount", "category"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "An food or drink item on the canteen menu",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique menu item ID" },
        "name": { "type": "string", "description": "Public name of canteen item" },
        "price": { "type": "number", "description": "The selling price" },
        "category": { "type": "string", "description": "Canteen section/category" },
        "is_available": { "type": "boolean", "description": "Operational availability" }
      },
      "required": ["id", "name", "price", "category"]
    },
    "MenuCategory": {
      "title": "MenuCategory",
      "description": "A category within the canteen menu",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "name": { "type": "string", "description": "The display name of the category" }
      },
      "required": ["id", "name"]
    },
    "HappyHourSettings": {
      "title": "HappyHourSettings",
      "description": "Pricing configurations for Happy Hours",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Document ID" },
        "isEnabled": { "type": "boolean", "description": "Active state" },
        "snookerRate": { "type": "number", "description": "Happy hour snooker hourly rate" },
        "poolRate": { "type": "number", "description": "Happy hour pool hourly rate" },
        "ps5Rate": { "type": "number", "description": "Happy hour PlayStation hourly rate" },
        "miniSnookerRate": { "type": "number", "description": "Happy hour mini-snooker hourly rate" },
        "otherRate": { "type": "number", "description": "Happy hour general hourly rate" },
        "lastEnabledAt": { "type": "string", "description": "ISO timestamp of when it was enabled" },
        "cumulativeDurationSeconds": { "type": "number", "description": "Total duration of HHour" },
        "updatedAt": { "type": "string", "description": "Update timestamp" }
      },
      "required": ["id", "isEnabled", "snookerRate", "poolRate", "ps5Rate", "miniSnookerRate", "otherRate", "updatedAt"]
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/AdminAccount" },
      "description": "Store active administrator metadata"
    },
    "/tables/{tableId}": {
      "schema": { "$ref": "#/entities/SnookerTable" },
      "description": "Real-time state and properties of snooker tables"
    },
    "/members/{memberId}": {
      "schema": { "$ref": "#/entities/Member" },
      "description": "Store registered member attributes"
    },
    "/billing_history/{historyId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Audit-trail or database of historic completed transactions"
    },
    "/expenditures/{expId}": {
      "schema": { "$ref": "#/entities/Expenditure" },
      "description": "Historical spend and operating expenses"
    },
    "/menu_items/{itemId}": {
      "schema": { "$ref": "#/entities/MenuItem" },
      "description": "Standard cafeteria and food stock pricing metadata"
    },
    "/menu_categories/{catId}": {
      "schema": { "$ref": "#/entities/MenuCategory" },
      "description": "Canteen categories"
    },
    "/happy_hour_settings/{settingId}": {
      "schema": { "$ref": "#/entities/HappyHourSettings" },
      "description": "Unique happy hour pricing rules"
    }
  }
}
